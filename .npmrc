# Redirect ONLY the pnpm virtual store (.pnpm folder) outside of ~/Desktop
# This is what iCloud actually locks — the tens of thousands of hard-linked files
# inside node_modules/.pnpm. The top-level node_modules symlink directory is tiny
# and safe to keep in the project.
virtual-store-dir=/Users/rindrajith/.shelby_node_modules/.pnpm-store

# Hoist Next.js and React to the workspace root so Turbopack can find them.
# Turbopack detects pnpm-workspace.yaml as the workspace root and looks for
# next/package.json from there. Without hoisting it fails with:
# "We couldn't find the Next.js package from the project directory"
public-hoist-pattern[]=next
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
