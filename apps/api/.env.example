# Shelby API Environment Variables
PORT=3000
NODE_ENV=development
MESSAGING_PROVIDER=mock  # 'mock' or 'meta'

# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=shelby_test_token
META_API_TOKEN=        # From Meta Developer Portal
META_PHONE_ID=         # WhatsApp Business Phone Number ID
META_APP_SECRET=       # App Secret for webhook HMAC verification
META_API_VERSION=v25.0
META_APP_ID=
META_BUSINESS_ACCOUNT_ID=
META_TEST_RECIPIENT=

# Infrastructure
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
REDIS_URL=             # Upstash Redis URL (rediss://...) for BullMQ message durability

# Upstash Redis REST — for rate limiting (works in serverless/edge)
UPSTASH_REDIS_REST_URL=    # From Upstash console → REST API
UPSTASH_REDIS_REST_TOKEN=  # From Upstash console → REST API

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhooks
SUPABASE_WEBHOOK_SECRET=
